---
const { title = "GetBench.io — Find & Benchmark AI Tools for LATAM" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; color: #1a1a1a; }
      nav { display: flex; justify-content: space-between; align-items: center; padding: 16px 32px; border-bottom: 1px solid #eee; }
      .logo { font-size: 18px; font-weight: 600; color: #1a1a1a; text-decoration: none; }
      .logo span { color: #1D9E75; }
      .nav-links { display: flex; gap: 24px; align-items: center; }
      .nav-links a { font-size: 14px; color: #555; text-decoration: none; }
      .nav-links a:hover { color: #1a1a1a; }
      .nav-submit { font-size: 12px; padding: 6px 14px; border: 1px solid #ddd; border-radius: 8px; color: #333; text-decoration: none; }
      .nav-submit:hover { background: #f5f5f5; }
      main { max-width: 1100px; margin: 0 auto; padding: 40px 32px; }
      .breadcrumb { display: flex; gap: 6px; align-items: center; font-size: 13px; color: #888; margin-bottom: 24px; flex-wrap: wrap; }
      .breadcrumb a { color: #888; text-decoration: none; }
      .breadcrumb a:hover { color: #1a1a1a; }
      .breadcrumb span { color: #ccc; }
      footer { text-align: center; padding: 32px; font-size: 13px; color: #888; border-top: 1px solid #eee; margin-top: 80px; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">Get<span>Bench</span>.io</a>
      <div class="nav-links">
        <a href="/en/categories">Categories</a>
        <a href="/en/compare">Compare</a>
        <a href="/en/blog">Blog</a>
        <a href="/en/submit" class="nav-submit">+ Submit a tool</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      © 2026 GetBench.io — The AI tools benchmark for LATAM
    </footer>
  </body>
</html>
