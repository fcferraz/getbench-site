---
import Base from '../layouts/Base.astro';
import { getCategories } from '../lib/airtable.js';

const categories = await getCategories();
---

<Base>
  <div style="text-align:center; padding: 60px 0 40px;">
    <div style="display:inline-block; font-size:12px; padding:4px 12px; background:#E1F5EE; color:#0F6E56; border-radius:20px; margin-bottom:20px;">
      340+ AI tools curated for LATAM
    </div>
    <h1 style="font-size:36px; font-weight:600; line-height:1.2; margin-bottom:16px;">
      Find the right AI tool<br/>for your business in LATAM
    </h1>
    <p style="font-size:16px; color:#555; max-width:480px; margin:0 auto 32px; line-height:1.6;">
      Compare pricing, features, and local availability.<br/>
      In Portuguese, Spanish, and English.
    </p>
    <div style="display:flex; gap:8px; justify-content:center; flex-wrap:wrap;">
      <a href="/en/category/sales-outreach" style="padding:10px 20px; background:#1D9E75; color:#fff; border-radius:8px; text-decoration:none; font-size:14px;">Browse categories</a>
      <a href="#" style="padding:10px 20px; border:1px solid #ddd; border-radius:8px; text-decoration:none; font-size:14px; color:#333;">Compare tools</a>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:48px;">
    {categories.map(cat => (
      <a href={`/en/category/${cat.Slug}`} style="padding:20px; border:1px solid #eee; border-radius:12px; text-decoration:none; color:inherit; display:block; transition: border-color 0.2s;">
        <div style="font-size:13px; font-weight:500; margin-bottom:4px;">{cat.Name}</div>
        <div style="font-size:12px; color:#888;">{cat.title_en}</div>
      </a>
    ))}
  </div>
</Base>
