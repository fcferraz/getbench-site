---
import Base from '../../layouts/Base.astro';
import { getCategories } from '../../lib/airtable.js';

const categories = await getCategories();
---

<Base title="All AI Tool Categories — GetBench.io">
  <div class="breadcrumb">
    <a href="/">Home</a><span>›</span>Categories
  </div>

  <h1 style="font-size:28px;font-weight:600;margin-bottom:8px;">Browse by category</h1>
  <p style="font-size:15px;color:#555;margin-bottom:40px;">Find the right AI tool for your specific use case, curated for LATAM businesses.</p>

  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
    {categories.map(cat => (
      <a href={`/en/category/${cat.Slug}`} style="padding:24px;border:1px solid #eee;border-radius:12px;text-decoration:none;color:inherit;display:block;">
        <div style="font-size:15px;font-weight:600;margin-bottom:6px;color:#1a1a1a;">{cat.Name}</div>
        <div style="font-size:13px;color:#888;margin-bottom:12px;line-height:1.5;">{cat.title_en}</div>
        <div style="font-size:12px;color:#1D9E75;font-weight:500;">Browse tools →</div>
      </a>
    ))}
  </div>
</Base>
