---
import Base from '../../../layouts/Base.astro';
import { getCategories, getToolsByCategory } from '../../../lib/airtable.js';

const { slug } = Astro.params;
const categories = await getCategories();
const category = categories.find(c => c.Slug === slug) || {};
const tools = await getToolsByCategory(category.Name || '');
---

<Base title={`${category.title_en} — GetBench.io`}>
  <div class="breadcrumb">
    <a href="/">Home</a><span>›</span>
    <a href="/en/categories">Categories</a><span>›</span>
    {category.Name}
  </div>

  <h1 style="font-size:28px;font-weight:600;margin-bottom:12px;">{category.title_en}</h1>
  <p style="font-size:15px;color:#555;margin-bottom:12px;max-width:600px;line-height:1.6;">
    {category.description_en || 'Compare the best AI tools for this category, curated for LATAM.'}
  </p>
  <p style="font-size:13px;color:#888;margin-bottom:20px;" id="tools-count">{tools.length} tools found</p>

  <div style="display:flex;gap:8px;margin-bottom:32px;flex-wrap:wrap;" id="filters">
    <button onclick="toggleFilter(this, 'all')" style="padding:6px 14px;border:1px solid #1D9E75;border-radius:20px;font-size:12px;cursor:pointer;background:#1D9E75;color:#fff;">All</button>
    <button onclick="toggleFilter(this, 'free')" style="padding:6px 14px;border:1px solid #ddd;border-radius:20px;font-size:12px;cursor:pointer;background:#fff;color:#555;">Free plan</button>
    <button onclick="toggleFilter(this, 'br')" style="padding:6px 14px;border:1px solid #ddd;border-radius:20px;font-size:12px;cursor:pointer;background:#fff;color:#555;">Works in BR</button>
    <button onclick="toggleFilter(this, 'brl')" style="padding:6px 14px;border:1px solid #ddd;border-radius:20px;font-size:12px;cursor:pointer;background:#fff;color:#555;">Accepts BRL</button>
    <button onclick="toggleFilter(this, 'pt')" style="padding:6px 14px;border:1px solid #ddd;border-radius:20px;font-size:12px;cursor:pointer;background:#fff;color:#555;">PT support</button>
  </div>

  {tools.length === 0 ? (
    <div style="padding:40px;background:#f9f9f9;border-radius:12px;text-align:center;color:#888;">
      Tools coming soon.
    </div>
  ) : (
    <div style="display:flex;flex-direction:column;gap:16px;" id="tools-list">
      {tools.map(tool => (
        <div class="tool-card" data-free={tool.has_free_plan ? '1' : '0'} data-br={tool.works_in_brazil ? '1' : '0'} data-brl={tool.accepts_brl ? '1' : '0'} data-pt={tool.has_pt_support ? '1' : '0'} style="padding:24px;border:1px solid #eee;border-radius:12px;display:flex;justify-content:space-between;align-items:flex-start;">
          <div style="flex:1;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap;">
              <a href={`/en/tools/${tool.slug}`} style="font-size:16px;font-weight:600;color:#1a1a1a;text-decoration:none;">{tool.Name}</a>
              {tool.works_in_brazil && <span style="font-size:11px;padding:2px 8px;background:#E6F1FB;color:#185FA5;border-radius:20px;">Works in BR</span>}
              {tool.has_free_plan && <span style="font-size:11px;padding:2px 8px;background:#E1F5EE;color:#0F6E56;border-radius:20px;">Free plan</span>}
            </div>
            <p style="font-size:13px;color:#555;margin-bottom:10px;">{tool.tagline_en}</p>
            {tool.latam_note_pt && (
              <p style="font-size:11px;color:#0F6E56;background:#E1F5EE;padding:4px 10px;border-radius:6px;display:inline-block;">{tool.latam_note_pt}</p>
            )}
          </div>
          <div style="text-align:right;margin-left:24px;flex-shrink:0;">
            <div style="font-size:14px;font-weight:500;margin-bottom:8px;">
              {tool.has_free_plan && tool.starting_price_usd === 0 ? 'Free' : `From $${tool.starting_price_usd}/mo`}
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;">
              <a href={`/en/tools/${tool.slug}`} style="display:inline-block;padding:6px 12px;border:1px solid #ddd;border-radius:6px;text-decoration:none;font-size:12px;color:#333;">Details</a>
              <a href={tool.affiliate_url || tool.website} target="_blank" style="display:inline-block;padding:6px 16px;background:#1D9E75;color:#fff;border-radius:6px;text-decoration:none;font-size:12px;">Visit →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  <script is:inline>
    function toggleFilter(btn, filter) {
      document.querySelectorAll('#filters button').forEach(b => {
        b.style.background = '#fff';
        b.style.color = '#555';
        b.style.borderColor = '#ddd';
      });
      btn.style.background = '#1D9E75';
      btn.style.color = '#fff';
      btn.style.borderColor = '#1D9E75';
      const cards = document.querySelectorAll('.tool-card');
      let visible = 0;
      cards.forEach(card => {
        let show = true;
        if (filter === 'free') show = card.dataset.free === '1';
        if (filter === 'br') show = card.dataset.br === '1';
        if (filter === 'brl') show = card.dataset.brl === '1';
        if (filter === 'pt') show = card.dataset.pt === '1';
        card.style.display = show ? 'flex' : 'none';
        if (show) visible++;
      });
      document.getElementById('tools-count').textContent = visible + ' tools found';
    }
  </script>
</Base>
