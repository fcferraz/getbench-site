---
import Base from '../../layouts/Base.astro';
---

<Base title="Submit a Tool — GetBench.io">
  <div class="breadcrumb">
    <a href="/">Home</a><span>›</span>Submit a tool
  </div>
  <div style="max-width:560px;margin:0 auto;padding:40px 0;">
    <h1 style="font-size:28px;font-weight:600;margin-bottom:12px;">Submit your AI tool</h1>
    <p style="font-size:15px;color:#555;margin-bottom:32px;line-height:1.6;">
      Want your tool listed on GetBench? We curate AI tools for the LATAM market. Send us your tool details and we'll review it.
    </p>
    <div style="padding:24px;border:1px solid #eee;border-radius:12px;background:#f9f9f9;text-align:center;">
      <p style="font-size:14px;color:#555;margin-bottom:16px;">Send an email with your tool name, website, and a brief description.</p>
      <a href="mailto:hello@getbench.io" style="display:inline-block;padding:10px 24px;background:#1D9E75;color:#fff;border-radius:8px;text-decoration:none;font-size:14px;">hello@getbench.io</a>
    </div>
  </div>
</Base>
