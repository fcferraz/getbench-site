---
import Base from '../../layouts/Base.astro';
import { getCategories } from '../../lib/airtable.js';
import { curatedComparisons } from '../../lib/comparisons.js';

const categories = await getCategories();
---

<Base title="Compare AI Tools — GetBench.io">
  <div class="breadcrumb">
    <a href="/">Home</a><span>›</span>Compare
  </div>

  <h1 style="font-size:28px;font-weight:600;margin-bottom:8px;">Compare AI tools</h1>
  <p style="font-size:15px;color:#555;margin-bottom:40px;max-width:600px;line-height:1.6;">
    Select a category and two tools to compare side by side.
  </p>

  <div style="padding:24px;border:1px solid #eee;border-radius:12px;margin-bottom:48px;background:#f9f9f9;">
    <h2 style="font-size:16px;font-weight:600;margin-bottom:20px;">Build your comparison</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:12px;align-items:end;">
      <div>
        <label style="font-size:12px;color:#888;display:block;margin-bottom:6px;">Category</label>
        <select id="sel-category" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:8px;font-size:13px;background:#fff;">
          <option value="">Select category...</option>
          {categories.map(cat => (
            <option value={cat.Slug}>{cat.Name}</option>
          ))}
        </select>
      </div>
      <div>
        <label style="font-size:12px;color:#888;display:block;margin-bottom:6px;">Tool A</label>
        <select id="sel-toolA" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:8px;font-size:13px;background:#fff;" disabled>
          <option value="">Select tool...</option>
        </select>
      </div>
      <div>
        <label style="font-size:12px;color:#888;display:block;margin-bottom:6px;">Tool B</label>
        <select id="sel-toolB" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:8px;font-size:13px;background:#fff;" disabled>
          <option value="">Select tool...</option>
        </select>
      </div>
      <button id="btn-compare" style="padding:9px 20px;background:#1D9E75;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;opacity:0.5;" disabled>
        Compare →
      </button>
    </div>
  </div>

  <h2 style="font-size:18px;font-weight:600;margin-bottom:20px;">Popular comparisons</h2>
  <div style="display:flex;flex-direction:column;gap:12px;">
    {curatedComparisons.map(({ category, slugA, slugB }) => {
      const catName = category.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      const labelA = slugA.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
      const labelB = slugB.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
      return (
        <a href={'/en/compare/' + category + '/' + slugA + '-vs-' + slugB}
          style="padding:16px 20px;border:1px solid #eee;border-radius:12px;text-decoration:none;color:inherit;display:flex;justify-content:space-between;align-items:center;">
          <div>
            <span style="font-size:14px;font-weight:500;color:#1a1a1a;">{labelA} vs {labelB}</span>
            <span style="font-size:12px;color:#888;margin-left:12px;">{catName}</span>
          </div>
          <span style="font-size:12px;color:#1D9E75;font-weight:500;">Compare →</span>
        </a>
      );
    })}
  </div>
</Base>

<script>
  const categorySelect = document.getElementById('sel-category');
  const toolASelect = document.getElementById('sel-toolA');
  const toolBSelect = document.getElementById('sel-toolB');
  const compareBtn = document.getElementById('btn-compare');
  const cache = {};

  categorySelect.addEventListener('change', async () => {
    const slug = categorySelect.value;
    if (!slug) return;
    toolASelect.innerHTML = '<option>Loading...</option>';
    toolBSelect.innerHTML = '<option>Loading...</option>';
    toolASelect.disabled = true;
    toolBSelect.disabled = true;
    if (!cache[slug]) {
      const res = await fetch('/api/tools-by-category?category=' + slug);
      cache[slug] = await res.json();
    }
    const opts = cache[slug].map(t => '<option value="' + t.slug + '">' + t.Name + '</option>').join('');
    toolASelect.innerHTML = '<option value="">Select tool A...</option>' + opts;
    toolBSelect.innerHTML = '<option value="">Select tool B...</option>' + opts;
    toolASelect.disabled = false;
    toolBSelect.disabled = false;
  });

  function checkReady() {
    const ok = categorySelect.value && toolASelect.value && toolBSelect.value && toolASelect.value !== toolBSelect.value;
    compareBtn.disabled = !ok;
    compareBtn.style.opacity = ok ? '1' : '0.5';
  }

  toolASelect.addEventListener('change', checkReady);
  toolBSelect.addEventListener('change', checkReady);

  compareBtn.addEventListener('click', () => {
    window.location.href = '/en/compare/' + categorySelect.value + '/' + toolASelect.value + '-vs-' + toolBSelect.value;
  });
</script>
